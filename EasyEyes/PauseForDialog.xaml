<Window x:Class="EasyEyes.PauseForDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pause for..."
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
    <StackPanel Margin="16" Orientation="Vertical">
        <TextBlock Text="Pause for how many minutes?" Margin="0,0,0,8"/>
        <TextBox x:Name="MinutesBox" Width="120" HorizontalAlignment="Left"
                 Text="30" PreviewTextInput="MinutesBox_PreviewTextInput"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="75" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Cancel" Width="75" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
